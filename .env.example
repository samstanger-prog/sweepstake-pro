# Mock mode — all fixtures from local data (no external API)
USE_MOCK_DATA=true

# Supabase — required (Project Settings → API at supabase.com/dashboard)
# Use the full URL and both keys; then run supabase/migrations/001_initial.sql
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Admin panel gate (set a strong secret)
ADMIN_SECRET=change-me-in-production
