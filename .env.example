# Mock mode — all fixtures from local data (no external API)
USE_MOCK_DATA=true

# Supabase — required (Project Settings → API at supabase.com/dashboard)
# Run migrations 001–004 in SQL Editor
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Admin panel gate (set a strong secret)
ADMIN_SECRET=change-me-in-production

# API-Football (server-only; when USE_MOCK_DATA=false — not fully implemented yet)
# API_FOOTBALL_API_KEY=your-api-sports-key
